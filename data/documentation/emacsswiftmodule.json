wift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"that can be easily used in Emacs Lisp"}]},{"syntax":"emacs-lisp","type":"codeListing","code":["(foo 1 1) ;; => 2","(bar [\"Hello\" \"World\"]) ;; => \"Hello, World\""]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It handles errors on both sides so the user can almost always simply ignore them."}]},{"syntax":"swift","type":"codeListing","code":["try env.defun(\"always-throws\") { (x: Int) throws in","  throw MyError(x: x)","}","try env.defun(\"calls-afdsiufs\") {","  (env: Environment) in","  do {","    try env.funcall(\"afdsiufs\", with: 42)","  } catch EmacsError.signal {","    print(\"Whoops! It looks like 'afdsiufs' doesn't exist!\")","  }","}"]},{"inlineContent":[{"text":"And on the Lisp side too","type":"text"}],"type":"paragraph"},{"code":["(always-throws 42) ;; => raises (swift-error \"Swift exception: MyError(x: 42)\")","(calls-afdsiufs) ;; => nil because we caught the error"],"type":"codeListing","syntax":"emacs-lisp"},{"type":"paragraph","inlineContent":[{"text":"The same happens when a type requirement expected in Swift is not met.","type":"text"}]},{"type":"codeListing","code":["(foo \"Hello\" \"World\") ;; => raises (wrong-type-argument numberp \"Hello\")"],"syntax":"emacs-lisp"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule"},"variants":[{"paths":["\/documentation\/emacsswiftmodule"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://EmacsSwiftModule/documentation/EmacsSwiftModule/EmacsError":{"url":"\/documentation\/emacsswiftmodule\/emacserror","abstract":[{"text":"The main type representing Emacs errors.","type":"text"}],"fragments":[{"text":"enum","kind":"keyword"},{"kind":"text","text":" "},{"text":"EmacsError","kind":"identifier"}],"title":"EmacsError","navigatorTitle":[{"kind":"identifier","text":"EmacsError"}],"kind":"s