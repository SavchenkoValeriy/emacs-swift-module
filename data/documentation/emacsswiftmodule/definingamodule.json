{"abstract":[{"type":"text","text":"Defining a new Emacs module from Swift."}],"primaryContentSections":[{"content":[{"type":"heading","level":2,"text":"EmacsSwiftModule installation","anchor":"EmacsSwiftModule-installation"},{"anchor":"Swift-Package-Manager","level":3,"type":"heading","text":"Swift Package Manager"},{"inlineContent":[{"type":"text","text":"Add the following line to you package dependencies:"}],"type":"paragraph"},{"code":[".package(\"https:\/\/github.com\/SavchenkoValeriy\/emacs-swift-module.git\", from: \"1.3.4\")"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Or add "},{"type":"codeVoice","code":"\"https:\/\/github.com\/SavchenkoValeriy\/emacs-swift-module.git\""},{"type":"text","text":" directly via Xcode."}]},{"text":"Module library","type":"heading","level":2,"anchor":"Module-library"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Make sure that you have a dynamic library product for your module target similar to the following code:"}]},{"syntax":"swift","code":["products: [","  .library(","    name: \"AwesomeSwiftEmacsModule\",","    type: .dynamic,","    targets: [\"AwesomeSwiftEmacsModule\"]),","],","dependencies: [","  .package(\"https:\/\/github.com\/SavchenkoValeriy\/emacs-swift-module.git\", from: \"1.3.4\")","],","targets: [","  .target(","    name: \"AwesomeSwiftEmacsModule\",","    dependencies: [","      .product(name: \"EmacsSwiftModuleDynamic\", package: \"emacs-swift-module\")","    ],","    plugins: [","      .plugin(name: \"ModuleFactoryPlugin\", package: \"emacs-swift-module\")","    ]","  )","]"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"And the target should depend on the ","type":"text"},{"code":"ModuleFactoryPlugin","type":"codeVoice"},{"type":"text","text":" to automatically setup C definitions required for each dynamic module."}]},{"type":"heading","text":"Writing a module code","anchor":"Writing-a-module-code","level":2},{"inlineContent":[{"type":"text","text":"Each module should have a class conforming to "},{"type":"reference","isActive":true,"identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/Module"},{"type":"text","text":". This protocol has only two requirements:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/Module\/isGPLCompatible"},{"text":", a boolean property that should always return true telling Emacs that your code is GPL-compatible.","type":"text"}]}]},{"content":[{"inlineContent":[{"identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/Module\/Init(_:)","isActive":true,"type":"reference"},{"text":", your module’s ","type":"text"},{"type":"codeVoice","code":"main"},{"type":"text","text":" function, it is called when Emacs loads your module."}],"type":"paragraph"}]}]},{"code":["import EmacsSwiftModule","","class AwesomeSwiftEmacsModule: Module {","  let isGPLCompatible = true","  func Init(_ env: Environment) throws {","    \/\/ initialize your module here","    try env.funcall(\"message\", \"Hello from Swift!\")","  }","}","","func createModule() -> Module { AwesomeSwiftEmacsModule() }"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"Now, if you compile this code with "},{"code":"swift build","type":"codeVoice"},{"type":"text","text":" and load it from Emacs via"}],"type":"paragraph"},{"syntax":"emacs-lisp","code":["(module-load \"SOURCE_DIR\/.build\/debug\/libYOUR_MODULE_NAME.dylib\")"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"you should see the ","type":"text"},{"type":"codeVoice","code":"\"Hello from Swift!\""},{"text":" message in your Emacs.","type":"text"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Uncaught exceptions in the "},{"type":"codeVoice","code":"Init"},{"text":" method prevent your module from loading, use that only when you absolutely cannot proceed.","type":"text"}]}],"style":"important","name":"Important","type":"aside"}],"kind":"content"}],"kind":"article","hierarchy":{"paths":[["doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/emacsswiftmodule\/definingamodule"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/DefiningAModule"},"metadata":{"role":"article","modules":[{"name":"EmacsSwiftModule"}],"title":"Defining a module","roleHeading":"Article"},"sections":[],"schemaVersion":{"minor":3,"major":0,"patch":0},"seeAlsoSections":[{"generated":true,"identifiers":["doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/CallingLispFunctions","doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/DefiningLispFunctions","doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/TypeConversions","doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/ErrorHandling"],"title":"Getting started"}],"references":{"doc://EmacsSwiftModule/documentation/EmacsSwiftModule/ErrorHandling":{"url":"\/documentation\/emacsswiftmodule\/errorhandling","type":"topic","title":"Error Handling","identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/ErrorHandling","kind":"article","role":"article","abstract":[{"type":"text","text":"Handling Lisp errors on Swift side and vice versa."}]},"doc://EmacsSwiftModule/documentation/EmacsSwiftModule/TypeConversions":{"url":"\/documentation\/emacsswiftmodule\/typeconversions","type":"topic","title":"Type conversions","identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/TypeConversions","kind":"article","role":"article","abstract":[{"type":"text","text":"Converting Swift values into Lisp values and vice versa."}]},"doc://EmacsSwiftModule/documentation/EmacsSwiftModule/DefiningLispFunctions":{"url":"\/documentation