{"primaryContentSections":[{"kind":"content","content":[{"anchor":"EmacsSwiftModule-installation","level":2,"type":"heading","text":"EmacsSwiftModule installation"},{"anchor":"Swift-Package-Manager","level":3,"type":"heading","text":"Swift Package Manager"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Add the following line to you package dependencies:"}]},{"type":"codeListing","syntax":"swift","code":[".package(\"https:\/\/github.com\/SavchenkoValeriy\/emacs-swift-module.git\", from: \"1.3.4\")"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Or add "},{"type":"codeVoice","code":"\"https:\/\/github.com\/SavchenkoValeriy\/emacs-swift-module.git\""},{"type":"text","text":" directly via Xcode."}]},{"anchor":"Module-library","level":2,"type":"heading","text":"Module library"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Make sure that you have a dynamic library product for your module target similar to the following code:"}]},{"type":"codeListing","syntax":"swift","code":["products: [","  .library(","    name: \"AwesomeSwiftEmacsModule\",","    type: .dynamic,","    targets: [\"AwesomeSwiftEmacsModule\"]),","],","dependencies: [","  .package(\"https:\/\/github.com\/SavchenkoValeriy\/emacs-swift-module.git\", from: \"1.3.4\")","],","targets: [","  .target(","    name: \"AwesomeSwiftEmacsModule\",","    dependencies: [","      .product(name: \"EmacsSwiftModuleDynamic\", package: \"emacs-swift-module\")","    ],","    plugins: [","      .plugin(name: \"ModuleFactoryPlugin\", package: \"emacs-swift-module\")","    ]","  )","]"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"And the target should depend on the "},{"type":"codeVoice","code":"ModuleFactoryPlugin"},{"type":"text","text":" to automatically setup C definitions required for each dynamic module."}]},{"anchor":"Writing-a-module-code","level":2,"type":"heading","text":"Writing a module code"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each module should have a class conforming to "},{"type":"reference","isActive":true,"identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/Module"},{"type":"text","text":". This protocol has only two requirements:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/Module\/isGPLCompatible"},{"type":"text","text":", a boolean property that should always return true telling Emacs that your code is GPL-compatible."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/Module\/Init(_:)"},{"type":"text","text":", your module’s "},{"type":"codeVoice","code":"main"},{"type":"text","text":" function, it is called when Emacs loads your module."}]}]}]},{"type":"codeListing","syntax":"swift","code":["import EmacsSwiftModule","","class AwesomeSwiftEmacsModule: Module {","  let isGPLCompatible = true","  func Init(_ env: Environment) throws {","    \/\/ initialize your module here","    try env.funcall(\"message\", \"Hello from Swift!\")","  }","}","","func createModule() -> Module { AwesomeSwiftEmacsModule() }"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Now, if you compile this code with "},{"type":"codeVoice","code":"swift build"},{"type":"text","text":" and load it from Emacs via"}]},{"type":"codeListing","syntax":"emacs-lisp","code":["(module-load \"SOURCE_DIR\/.build\/debug\/libYOUR_MODULE_NAME.dylib\")"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"you should see the "},{"type":"codeVoice","code":"\"Hello from Swift!\""},{"type":"text","text":" message in your Emacs."}]},{"style":"important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Uncaught exceptions in the "},{"type":"codeVoice","code":"Init"},{"type":"text","text":" method prevent your module from loading, use that only when you absolutely cannot proceed."}]}],"type":"aside","name":"Important"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"variants":[{"paths":["\/documentation\/emacsswiftmodule\/definingamodule"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/DefiningAModule","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Defining a new Emacs module from Swift."}],"kind":"article","metadata":{"roleHeading":"Article","title":"Defining a module","role":"article","modules":[{"name":"EmacsSwiftModule"}]},"hierarchy":{"paths":[["doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule"]]},"seeAlsoSections":[{"title":"Getting started","identifiers":["doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/CallingLispFunctions","doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/DefiningLispFunctions","doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/TypeConversions","doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/ErrorHandling"],"generated":true}],"references":{"doc://EmacsSwiftModule/documentation/EmacsSwiftModule/CallingLispFunctions":{"role":"article","title":"Calling Lisp Functions","abstract":[{"type":"text","text":"Calling Lisp functions from your Swift code."}],"identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/CallingLispFunctions","kind":"article","type":"topic","url":"\/documentation\/emacsswiftmodule\/callinglispfunctions"},"doc://EmacsSwiftModule/documentation/EmacsSwiftModule/Module/isGPLCompatible":{"role":"symbol","title":"isGPLCompatible","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"isGPLCompatible"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"abstract":[{"type":"text","text":"Every dynamic module should be distributed under the GPL compatible license."}],"identifier":"doc:\/