ftModule\/EmacsError\/lifetimeViolation","url":"\/documentation\/emacsswiftmodule\/emacserror\/lifetimeviolation","type":"topic","role":"symbol","kind":"symbol","abstract":[{"type":"text","text":"Using "},{"isActive":true,"type":"reference","identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/Environment"},{"type":"text","text":" outside of its scope."}]},"doc://EmacsSwiftModule/documentation/EmacsSwiftModule/EmacsError/interrupted":{"title":"EmacsError.interrupted","fragments":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"interrupted"}],"identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/EmacsError\/interrupted","url":"\/documentation\/emacsswiftmodule\/emacserror\/interrupted","type":"topic","role":"symbol","kind":"symbol","abstract":[{"type":"text","text":"Emacs user interruption (C-g)."}]},"doc://EmacsSwiftModule/documentation/EmacsSwiftModule/Environment/interrupted()":{"abstract":[{"type":"text","text":"Checks whether the user interrupted execution of the current function."}],"title":"interrupted()","type":"topic","identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/Environment\/interrupted()","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"interrupted"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}],"kind":"symbol","url":"\/documentation\/emacsswiftmodule\/environment\/interrupted()","role":"symbol"},"doc://EmacsSwiftModule/documentation/EmacsSwiftModule":{"role":"collection","abstract":[{"type":"text","text":"A Swift library to write Emacs plugins in Swift!"}],"type":"topic","identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule","url":"\/documentation\/emacsswiftmodule","title":"EmacsSwiftModule","kind":"symbol"},"doc://EmacsSwiftModule/documentation/EmacsSwiftModule/Lifetimes":{"url":"\/documentation\/emacsswiftmodule\/lifetimes","