{"hierarchy":{"paths":[["doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule"],["doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule","doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/Environment"]]},"variants":[{"paths":["\/documentation\/emacsswiftmodule\/callinglispfunctions"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"seeAlsoSections":[{"identifiers":["doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/DefiningAModule","doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/DefiningLispFunctions","doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/TypeConversions","doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/ErrorHandling"],"generated":true,"title":"Getting started"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"modules":[{"name":"EmacsSwiftModule"}],"roleHeading":"Article","role":"article","title":"Calling Lisp Functions"},"kind":"article","identifier":{"url":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/CallingLispFunctions","interfaceLanguage":"swift"},"primaryContentSections":[{"content":[{"level":2,"type":"heading","anchor":"funcall-and-apply","text":"funcall and apply"},{"inlineContent":[{"type":"text","text":"Similarly to Emacs Lisp functions "},{"type":"codeVoice","code":"funcall"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"apply"},{"text":", ","type":"text"},{"isActive":true,"identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/Environment","type":"reference"},{"type":"text","text":" provides methods with the same names with similar semantics. In 99% of the cases you’ll need "},{"type":"codeVoice","code":"funcall"},{"type":"text","text":", which accepts a function to call and whatever arguments you pass with it. Every function has a structure."}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["env.funcall(\"lisp-function\", with: 42, 36.6, true, \"String\", [10, 20, 30])"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"As you can see, it accepts and properly converts native Swift types and values into their Lisp counterparts."},{"text":" ","type":"text"},{"text":"If something goes wrong on the Emacs side, this call will throw ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/EmacsError"},{"type":"text","text":". This can represent any error you usually see in Emacs, "},{"code":"void-function","type":"codeVoice"},{"text":" for missing function with that name, or ","type":"text"},{"code":"wrong-type-argument","type":"codeVoice"},{"type":"text","text":", etc."}]},{"inlineContent":[{"type":"text","text":"The only difference "},{"code":"apply","type":"codeVoice"},{"text":" function has over ","type":"text"},{"type":"codeVoice","code":"funcall"},{"type":"text","text":" is that it accepts an array of all of the call arguments as its second argument. So, it can be of use if you construct your arguments list in runtime."}],"type":"paragraph"},{"inlineContent":[{"text":"By default, ","type":"text"},{"code":"funcall","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"apply"},{"type":"text","text":" return an opaque "},{"identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/EmacsValue","isActive":true,"type":"reference"},{"type":"text","text":" (see "},{"isActive":true,"type":"reference","identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/TypeConversions"},{"type":"text","text":") that represents some dynamically typed Lisp value. All of the values under the hood are "},{"identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/EmacsValue","isActive":true,"type":"reference"},{"text":". However, both of these functions have a bit of generic magic to it, and if the return type should be something different and it is clear from the context, the environment will try to convert it for you.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Let’s consider the following example:"}],"type":"paragraph"},{"syntax":"swift","code":["let result = try env.funcall(\"format\", with \"%S: %S\", 42, \"42\")"],"type":"codeListing"},{"inlineContent":[{"text":"This will produce ","type":"text"},{"identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/EmacsValue","type":"reference","isActive":true},{"text":", but if we change it to either","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["let result1: String = try env.funcall(\"format\", with \"%S: %S\", 42, \"42\")","let result2 = try env.funcall(\"format\", with \"%S: %S\", 42, \"42\") as String","acceptsString(try env.funcall(\"format\", with \"%S: %S\", 42, \"42\"))"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"it will get correctly converted into Swift’s own ","type":"text"},{"code":"String","type":"codeVoice"},{"type":"text","text":"."}]}],"kind":"content"}],"abstract":[{"type":"text","text":"Calling Lisp functions from your Swift code."}],"references":{"doc://EmacsSwiftModule/documentation/EmacsSwiftModule/EmacsError":{"url":"\/documentation\/emacsswiftmodule\/emacserror","abstract":[{"text":"The main type representing Emacs errors.","type":"text"}],"fragments":[{"text":"enum","kind":"keyword"},{"kind":"text","text":" "},{"text":"EmacsError","kind":"identifier"}],"title":"EmacsError","navigatorTitle":[{"kind":"identifier","text":"EmacsError"}],"kind":"symbol","identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/EmacsError","role":"symbol","type":"topic"},"doc://EmacsSwiftModule/documentation/EmacsSwiftModule/EmacsValue":{"abstract":[{"text":"An opaque Emacs value representing something from the Emacs Lisp world.","type":"text"}],"url":"\/documentation\/emacsswiftmodule\/emacsvalue","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"EmacsValue"}],"title":"EmacsValue","navigatorTitle":[{"text":"EmacsValue","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/EmacsValue","role":"symbol","type":"topic"},"doc://EmacsSwiftModule/documentation/EmacsSwiftModule/DefiningLispFunctions":{"url":"\/documentation\/emacsswiftmodule\/defininglispfunctions","title":"Defining Lisp Functions","role":"article","kind":"article","identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/DefiningLispFunctions","type":"topic","abstract":[{"type":"text","text":"Defining Emacs Lisp functions directly from Swift."}]},"doc://EmacsSwiftModule/documentation/EmacsSwiftModule/TypeConversions":{"url":"\/documentation\/emacsswiftmodule\/typeconversions","type":"topic","title":"Type conversions","identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/TypeConversions","kind":"article","role":"article","abstract":[{"type":"text","text":"Converting Swift values into Lisp values and vice versa."}]},"doc://EmacsSwiftModule/documentation/EmacsSwiftModule":{"role":"collection","kind":"symbol","url":"\/documentation\/emacsswiftmodule","identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule","abstract":[{"type":"text","text":"A Swift library to write Emacs plugins in Swift!"}],"title":"EmacsSwiftModule","type":"topic"},"doc://EmacsSwiftModule/documentation/EmacsSwiftModule/Environment":{"abstract":[{"type":"text","text":"Environment is the interaction point with Emacs. If you want to do anything on the Emacs side, you need to have an Environment."}],"title":"Environment","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"Environment","kind":"identifier"}],"navigatorTitle":[{"text":"Environment","kind":"identifier"}],"role":"symbol","kind":"symbol","identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/Environment","type":"topic","url":"\/documentation\/emacsswiftmodule\/environment"},"doc://EmacsSwiftModule/documentation/EmacsSwiftModule/ErrorHandling":{"url":"\/documentation\/emacsswiftmodule\/errorhandling","type":"topic","title":"Error Handling","identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/ErrorHandling","kind":"article","role":"article","abstract":[{"type":"text","text":"Handling Lisp errors on Swift side and vice versa."}]},"doc://EmacsSwiftModule/documentation/EmacsSwiftModule/DefiningAModule":{"url":"\/documentation\/emacsswiftmodule\/definingamodule","type":"topic","title":"Defining a module","identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/DefiningAModule","kind":"article","role":"article","abstract":[{"type":"text","text":"Defining a new Emacs module from Swift."}]}}}