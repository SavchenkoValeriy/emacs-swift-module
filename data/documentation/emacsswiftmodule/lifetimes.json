{"kind":"article","schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"text":"Emacs internals lifetimes.","type":"text"}],"identifier":{"url":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/Lifetimes","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule"],["doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule","doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/Environment"]]},"metadata":{"role":"article","modules":[{"name":"EmacsSwiftModule"}],"title":"Lifetimes","roleHeading":"Article"},"seeAlsoSections":[{"title":"Advanced","identifiers":["doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/AsyncCallbacks"],"generated":true}],"primaryContentSections":[{"kind":"content","content":[{"text":"Environment Lifetime","type":"heading","anchor":"Environment-Lifetime","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Environment lives as long as the function it was given to executes. This covers both module initialization and Lisp functions defined in Swift. Using environment outside of its lifetime will most likely crash Emacs. You can think of "},{"identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/Environment","isActive":true,"type":"reference"},{"text":" to be always an unowned reference.","type":"text"}]},{"inlineContent":[{"type":"text","text":"This means that storing "},{"identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/Environment","type":"reference","isActive":true},{"type":"text","text":" as part of some state, or capturing it in a closure that will be used afterwards is not going to work. The most typical problem looks somwehat like this:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["try env.defun(\"test\") {","  \/\/ some code before","  try env.funcall(\"lisp-function\")","  \/\/ some code after","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When the function does a lot of things, it’s hard to spot the fact that we are actually using the wrong environment. We captured the one from the outer scope, and using it here will cause Emacs to crash. Instead, we can explicitly ask for a new instance of "},{"identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/Environment","type":"reference","isActive":true},{"type":"text","text":" in every Swift-defined Lisp function."}]},{"type":"codeListing","syntax":"swift","code":["try env.defun(\"test\") {","  (env: Environment) in","  \/\/ some code before","  try env.funcall(\"lisp-function\")","  \/\/ some code after","}"]},{"type":"paragraph","inlineContent":[{"text":"This code doesn’t change the number of required arguments to call ","type":"text"},{"type":"codeVoice","code":"test"},{"type":"text","text":", Emacs already passes a new environment with every function invocation. This way we just ask "},{"isActive":true,"identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/Environment","type":"reference"},{"text":" to pass it to us on call.","type":"text"}]},{"inlineContent":[{"text":"This lifetime restriction ensures one of the core principles of Emacs dynamic modules ","type":"text"},{"type":"strong","inlineContent":[{"text":"“Emacs calls into then module’s code when it wants to, not the other way around”","type":"text"}]},{"text":". Using ","type":"text"},{"identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/Environment","isActive":true,"type":"reference"},{"type":"text","text":" outside of its lifetime means calling into Emacs asynchronously when Emacs does not expect it to happen. That will violate its concurrency model."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In order to ensure this requirement, "},{"identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/Environment","isActive":true,"type":"reference"},{"type":"text","text":" has additional checks in place to spot lifetime violations and throw "},{"type":"reference","identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/EmacsError\/lifetimeViolation","isActive":true},{"type":"text","text":" exception when it does. This way the very first snippet from this section won’t actually crash Emacs, but simply signal an error when calling the "},{"type":"codeVoice","code":"test"},{"text":" function.","type":"text"}]},{"level":2,"text":"EmacsValue Lifetime","anchor":"EmacsValue-Lifetime","type":"heading"},{"inlineContent":[{"type":"text","text":"Similarly to "},{"type":"reference","identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/Environment","isActive":true},{"text":", opaque ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/EmacsValue"},{"type":"text","text":" also has a limited lifetime. It is not enforced as strictly, and can produce even more confusion."}],"type":"paragraph"},{"inlineContent":[{"text":"Essentially every ","type":"text"},{"type":"reference","identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/EmacsValue","isActive":true},{"text":" is bound to the ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/Environment"},{"type":"text","text":" instance that produced it. This means that "},{"isActive":true,"identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/EmacsValue","type":"reference"},{"type":"text","text":" has "},{"type":"emphasis","inlineContent":[{"type":"text","text":"the same lifetime"}]},{"text":" as its ","type":"text"},{"identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/Environment","isActive":true,"type":"reference"},{"type":"text","text":". In the most probable scenario, you produce a value and use it with the same environment. Nothing to worry about in this case!"}],"type":"paragraph"},{"code":["let value = try env.funcall(\"foo\")","try env.funcall(\"bar\", with: value)"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"The problem comes when you want to keep certain value and share it between two environments."}],"type":"paragraph"},{"code":["var stash: EmacsValue = env.Nil","try env.defun(\"stash-arg\") {","  (arg: EmacsValue) in stash = arg","}","try env.defun(\"get-stash\") {","  stash","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It should not work because of the lifetimes violation, but in most cases it does. On my machine, this code works as the user expected it to work. However, if we modify it a little bit, we can receive some very confusing results."}]},{"syntax":"swift","code":["var stash = [EmacsValue]()","try env.defun(\"stash-arg\") {","  (arg: EmacsValue) in stash.append(arg)","}","try env.defun(\"get-stash\") {","  stash","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Looks very much the same, we keep all the arguments instead of the last one. So, what would be the problem?"}]},{"type":"codeListing","syntax":"emacs-lisp","code":["(stash-arg 1)","(stash-arg 2)","(stash-arg 3)","(get-stash) ;; => [3 3 3]"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It returns a vector of "},{"type":"codeVoice","code":"3"},{"text":"s! The size is right, the last value is right, but the whole vector shares the same value. It is especially strange after the previous example. The reason is the lifetime of ","type":"text"},{"code":"arg","type":"codeVoice"},{"text":", in this situation it is not enforced. However, Emacs reuses the same memory to store a new argument value every time. It is just an implementation detail of Emacs that we discovered accidentally. We should ","type":"text"},{"inlineContent":[{"type":"text","text":"never"}],"type":"emphasis"},{"type":"text","text":" rely on such undocumented features. They can change from one release to another, and behave differently on different platforms."}]},{"inlineContent":[{"type":"text","text":"Instead, we should use "},{"isActive":true,"identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/PersistentEmacsValue","type":"reference"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["var stash = [EmacsValue]()","try env.defun(\"stash-arg\") {","  (arg: PersistentEmacsValue) in stash.append(arg)","}","try env.defun(\"get-stash\") {","  stash","}"]},{"inlineContent":[{"type":"text","text":"This fixes it! We just changed parameter type of our function and that’s enough! This way we tell "},{"code":"EmacsSwiftModule","type":"codeVoice"},{"type":"text","text":" that actually the Swift side should take care of this value’s lifetime. "},{"type":"reference","isActive":true,"identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/PersistentEmacsValue"},{"type":"text","text":" effectively marries Swift’s ARC and Emacs’ garbage collection, so we can share values across environments."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/PersistentEmacsValue"},{"type":"text","text":" also works with "},{"type":"codeVoice","code":"funcall"},{"text":" and ","type":"text"},{"code":"apply","type":"codeVoice"},{"text":" result type inference, so you can write:","type":"text"}]},{"code":["let x: PersistentEmacsValue = try env.funcall(\"foo\")","let y = try env.funcall(\"bar\") as PersistentEmacsValue"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"If you already have ","type":"text"},{"type":"reference","identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/EmacsValue","isActive":true},{"text":", you can turn it into ","type":"text"},{"identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/PersistentEmacsValue","type":"reference","isActive":true},{"type":"text","text":" by calling "},{"isActive":true,"type":"reference","identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/Environment\/preserve(_:)"},{"text":".","type":"text"}]},{"syntax":"swift","code":["let lambda = try env.preserve(env.defun {","  \/\/ do some cool stuff","})"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"After preservation, ","type":"text"},{"code":"lambda","type":"codeVoice"},{"type":"text","text":" can be safely used from different functions."}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/Environment"},{"text":" also provides ","type":"text"},{"type":"reference","identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/Environment\/retain(_:)","isActive":true},{"text":" and ","type":"text"},{"identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/Environment\/release(_:)","type":"reference","isActive":true},{"text":" low-level APIs for manual reference-counting. But ","type":"text"},{"identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/PersistentEmacsValue","isActive":true,"type":"reference"},{"type":"text","text":" and "},{"type":"reference","isActive":true,"identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/Environment\/preserve(_:)"},{"type":"text","text":" should be preferred to avoid mistakes."}]}],"type":"aside","style":"note","name":"Info"},{"type":"heading","text":"Concurrency","level":2,"anchor":"Concurrency"},{"inlineContent":[{"type":"text","text":"As it was mentioned earlier, "},{"isActive":true,"type":"reference","identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/Environment"},{"text":" lifetime restriction comes from the desire to keep Emacs own concurrency model intact. This also includes another rule for using ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/Environment"},{"type":"text","text":" - it should be used on the same thread it was created on. It is important to keep it mind, even considering that using "},{"isActive":true,"type":"reference","identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/Environment"},{"type":"text","text":" asynchronously will most likely violate its lifetime. To learn how to mix asynchronous code with Emacs interactions, please refer to "},{"identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/AsyncCallbacks","type":"reference","isActive":true},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Similarly to lifetime violations, "},{"type":"reference","isActive":true,"identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/Environment"},{"type":"text","text":" validates that its user follows Emacs concurrency model and throws "},{"identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/EmacsError\/threadModelViolation","isActive":true,"type":"reference"},{"type":"text","text":" when "},{"type":"reference","identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/Environment","isActive":true},{"type":"text","text":" is attempted to be used on the other thread."}],"type":"paragraph"}]}],"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/emacsswiftmodule\/lifetimes"]}],"references":{"doc://EmacsSwiftModule/documentation/EmacsSwiftModule/Environment/retain(_:)":{"url":"\/documentation\/emacsswiftmodule\/environment\/retain(_:)","identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/Environment\/retain(_:)","role":"symbol","abstract":[{"text":"Retain the given value.","type":"text"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"retain","kind":"identifier"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"EmacsValue","preciseIdentifier":"s:16EmacsSwiftModule0A5ValueC"},{"text":") ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:16EmacsSwiftModule0A5ValueC","text":"EmacsValue","kind":"typeIdentifier"}],"kind":"symbol","type":"topic","title":"retain(_:)"},"doc://EmacsSwiftModule/documentation/EmacsSwiftModule/Environment":{"abstract":[{"type":"text","text":"Environment is the interaction point with Emacs. If you want to do anything on the Emacs side, you need to have an Environment."}],"title":"Environment","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"Environment","kind":"identifier"}],"navigatorTitle":[{"text":"Environment","kind":"identifier"}],"role":"symbol","kind":"symbol","identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/Environment","type":"topic","url":"\/documentation\/emacsswiftmodule\/environment"},"doc://EmacsSwiftModule/documentation/EmacsSwiftModule/EmacsError/threadModelViolation":{"title":"EmacsError.threadModelViolation","fragments":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"threadModelViolation"}],"role":"symbol","identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/EmacsError\/threadModelViolation","url":"\/documentation\/emacsswiftmodule\/emacserror\/threadmodelviolation","kind":"symbol","abstract":[{"type":"text","text":"Using "},{"identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/Environment","type":"reference","isActive":true},{"type":"text","text":" in a different thread than issued it."}],"type":"topic"},"doc://EmacsSwiftModule/documentation/EmacsSwiftModule/PersistentEmacsValue":{"abstract":[{"type":"text","text":"An Emacs value that can be safely copied and stored."}],"url":"\/documentation\/emacsswiftmodule\/persistentemacsvalue","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"PersistentEmacsValue","kind":"identifier"}],"title":"PersistentEmacsValue","navigatorTitle":[{"text":"PersistentEmacsValue","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/PersistentEmacsValue","role":"symbol","type":"topic"},"doc://EmacsSwiftModule/documentation/EmacsSwiftModule/EmacsValue":{"abstract":[{"text":"An opaque Emacs value representing something from the Emacs Lisp world.","type":"text"}],"url":"\/documentation\/emacsswiftmodule\/emacsvalue","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"EmacsValue"}],"title":"EmacsValue","navigatorTitle":[{"text":"EmacsValue","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/EmacsValue","role":"symbol","type":"topic"},"doc://EmacsSwiftModule/documentation/EmacsSwiftModule/Environment/release(_:)":{"url":"\/documentation\/emacsswiftmodule\/environment\/release(_:)","abstract":[{"text":"Release the given value.","type":"text"}],"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"release","kind":"identifier"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"EmacsValue","preciseIdentifier":"s:16EmacsSwiftModule0A5ValueC"},{"text":") ","kind":"text"},{"text":"throws","kind":"keyword"}],"title":"release(_:)","kind":"symbol","identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/Environment\/release(_:)","role":"symbol","type":"topic"},"doc://EmacsSwiftModule/documentation/EmacsSwiftModule/Environment/preserve(_:)":{"url":"\/documentation\/emacsswiftmodule\/environment\/preserve(_:)","abstract":[{"text":"Return a persistent version of the given value.","type":"text"}],"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"preserve"},{"text":"(","kind":"text"},{"preciseIdentifier":"s:16EmacsSwiftModule0A5ValueC","kind":"typeIdentifier","text":"EmacsValue"},{"text":") ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"PersistentEmacsValue","preciseIdentifier":"s:16EmacsSwiftModule010PersistentA5ValueC","kind":"typeIdentifier"}],"title":"preserve(_:)","kind":"symbol","identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/Environment\/preserve(_:)","role":"symbol","type":"topic"},"doc://EmacsSwiftModule/documentation/EmacsSwiftModule/AsyncCallbacks":{"role":"article","kind":"article","url":"\/documentation\/emacsswiftmodule\/asynccallbacks","title":"Asynchronous Callbacks","abstract":[{"text":"Calling Lisp functions without an active Environment.","type":"text"}],"identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/AsyncCallbacks","type":"topic"},"doc://EmacsSwiftModule/documentation/EmacsSwiftModule":{"role":"collection","kind":"symbol","url":"\/documentation\/emacsswiftmodule","identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule","abstract":[{"type":"text","text":"A Swift library to write Emacs plugins in Swift!"}],"title":"EmacsSwiftModule","type":"topic"},"doc://EmacsSwiftModule/documentation/EmacsSwiftModule/EmacsError/lifetimeViolation":{"role":"symbol","title":"EmacsError.lifetimeViolation","fragments":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"lifetimeViolation"}],"kind":"symbol","type":"topic","abstract":[{"type":"text","text":"Using "},{"isActive":true,"identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/Environment","type":"reference"},{"text":" outside of its scope.","type":"text"}],"identifier":"doc:\/\/EmacsSwiftModule\/documentation\/EmacsSwiftModule\/EmacsError\/lifetimeViolation","url":"\/documentation\/emacsswiftmodule\/emacserror\/lifetimeviolation"}}}